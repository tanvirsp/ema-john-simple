;\r\n    const [cart, setCart] = useState([]);\r\n\r\n    \r\n    //product handelar\r\n    const handleAddProduct = (product) => {\r\n        console.log('Product Added', product);\r\n        const newCart = [...cart, product];\r\n        setCart(newCart);\r\n    }\r\n    \r\n    return (\r\n        <div className =\"shop-container\">\r\n            <div className=\"product-container\">\r\n                {\r\n                    products.map(product => <Product \r\n                        product = {product} \r\n                        handleAddProduct ={handleAddProduct}>                          \r\n                        </Product>)\r\n                }\r\n            </div>\r\n            <div className=\"cart-container\">\r\n                <Cart cart = {cart}></Cart>\r\n            </div>\r\n          \r\n        </div>\r\n    );\r\n};\r\n\r\nexport default Shop;\r\n\r\n","G:\\Jhonkar Mahbub Cource\\react work\\ema-john-simple\\src\\fakeData\\index.js",[],"G:\\Jhonkar Mahbub Cource\\react work\\ema-john-simple\\src\\fakeData\\android.js",[],"G:\\Jhonkar Mahbub Cource\\react work\\ema-john-simple\\src\\fakeData\\camera.js",[],"G:\\Jhonkar Mahbub Cource\\react work\\ema-john-simple\\src\\fakeData\\laptop.js",[],"G:\\Jhonkar Mahbub Cource\\react work\\ema-john-simple\\src\\components\\Product\\Product.js",[],"G:\\Jhonkar Mahbub Cource\\react work\\ema-john-simple\\src\\components\\Cart\\Cart.js",[],{"ruleId":"51","replacedBy":"52"},{"ruleId":"53","replacedBy":"54"},{"ruleId":"55","severity":1,"message":"56","line":9,"column":22,"nodeType":"57","messageId":"58","endLine":9,"endColumn":33},"no-native-reassign",["59"],"no-negated-in-lhs",["60"],"no-unused-vars","'setProducts' is assigned a value but never used.","Identifier","unusedVar","no-global-assign","no-unsafe-negation"]